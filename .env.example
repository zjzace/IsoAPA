# APA Atlas - Environment Configuration
# Copy this file to .env and modify the values

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/apa_atlas

# Application Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# API Configuration
API_VERSION=v1
DATA_VERSION=1.0

# Frontend Configuration (optional - for production)
FRONTEND_URL=http://localhost:8000

# Logging
LOG_LEVEL=INFO

# Session
SECRET_KEY=your-secret-key-change-in-production
